# Postgres Supabase (pooler transaction, porta 6543)
# Formato: postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# OBS: connection_limit=10 -> engine OTC abre varias conexoes em paralelo (5 ativos x 4 timeframes).
# Com pgbouncer=true, Prisma ja desabilita prepared statements -> seguro subir o limit ate o pool size do projeto.
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# URL publica do projeto Supabase (sem barra final).
# Fastify usa essa URL para buscar JWKS em /auth/v1/.well-known/jwks.json
SUPABASE_URL="https://PROJECT_REF.supabase.co"

PORT=3001
FRONTEND_URL="http://localhost:3000"
DEMO_INITIAL_BALANCE=10000
NODE_ENV="development"

# ── Gateway de pagamento BSPay (Pix) — doc: https://dev.bspay.co ─────────────
# Nunca commitar valores reais. Confirmar se ha base URL/credenciais de sandbox.
BSPAY_BASE_URL="https://api.bspay.co"
BSPAY_CLIENT_ID=""         # ex: janielmadeira_5461561599193762
BSPAY_CLIENT_SECRET=""     # secret do par de credenciais (tela Credenciais > Gerenciar)
BSPAY_SIGNING_KEY=""       # chave que assina o cash-out (X-Signature) — pode ser a mesma do secret; confirmar na doc
BSPAY_WEBHOOK_SECRET=""    # valida X-Webhook-Signature (HMAC-SHA256) dos webhooks recebidos
# URL publica que recebe os webhooks; passada como postback_url em cada transacao
# (dispensa configurar no dashboard). Em producao: https://api.vertexmarkets.co/webhooks/bspay
BSPAY_POSTBACK_URL="https://api.vertexmarkets.co/webhooks/bspay"
MIN_DEPOSIT=10
MIN_WITHDRAWAL=20
