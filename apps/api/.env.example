# Postgres Supabase (pooler transaction, porta 6543)
# Formato: postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGIAO.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# OBS: connection_limit=10 -> engine OTC abre varias conexoes em paralelo (5 ativos x 4 timeframes).
# Com pgbouncer=true, Prisma ja desabilita prepared statements -> seguro subir o limit ate o pool size do projeto.
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# URL publica do projeto Supabase (sem barra final).
# Fastify usa essa URL para buscar JWKS em /auth/v1/.well-known/jwks.json
SUPABASE_URL="https://PROJECT_REF.supabase.co"

PORT=3001
FRONTEND_URL="http://localhost:3000"
DEMO_INITIAL_BALANCE=10000
NODE_ENV="development"

# ── Gateway de pagamento BSPay (Pix) ─────────────────────────────────────────
# Usar credenciais de SANDBOX/homologacao primeiro. Nunca commitar valores reais.
BSPAY_BASE_URL=""          # ex: https://sandbox.bspay.co  (confirmar na doc)
BSPAY_CLIENT_ID=""
BSPAY_CLIENT_SECRET=""
BSPAY_WEBHOOK_SECRET=""    # segredo para validar X-SIGNATURE (HMAC-SHA256) dos webhooks
MIN_DEPOSIT=10
MIN_WITHDRAWAL=20
