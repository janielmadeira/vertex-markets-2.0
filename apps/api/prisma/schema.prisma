generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AccountType {
  DEMO
  REAL
}

enum Direction {
  CALL
  PUT
}

enum OperationStatus {
  OPEN
  WON
  LOST
  CANCELLED
}

enum TransactionType {
  DEMO_CREDIT
  DEPOSIT
  WITHDRAWAL
  TRADE_WIN
  TRADE_LOSS
  BONUS
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum OtcAssetStatus {
  ACTIVE
  INACTIVE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  phone     String?
  country   String?
  kycStatus KycStatus @default(PENDING)
  role      UserRole  @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts Account[]

  @@map("users")
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  currency  String      @default("BRL")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  operations   Operation[]
  transactions Transaction[]

  @@unique([userId, type])
  @@map("accounts")
}

model Operation {
  id          String          @id @default(cuid())
  accountId   String
  assetId     String
  assetSymbol String
  direction   Direction
  amount      Decimal         @db.Decimal(18, 2)
  payout      Int
  entryPrice  Decimal         @db.Decimal(18, 5)
  exitPrice   Decimal?        @db.Decimal(18, 5)
  profit      Decimal?        @db.Decimal(18, 2)
  status      OperationStatus @default(OPEN)
  expiresAt   DateTime
  openedAt    DateTime        @default(now())
  closedAt    DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([expiresAt, status])
  @@map("operations")
}

model OtcAsset {
  id              String         @id @default(cuid())
  symbol          String         @unique
  name            String
  basePrice       Decimal        @db.Decimal(18, 5)
  volatility      Decimal        @default(0.0010) @db.Decimal(8, 6)
  trend           Decimal        @default(0) @db.Decimal(8, 6)
  payout          Int            @default(85)
  decimals        Int            @default(5)
  status          OtcAssetStatus @default(ACTIVE)
  sessionStartUtc String?
  sessionEndUtc   String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  candles OtcCandle[]

  @@map("otc_assets")
}

model OtcCandle {
  id        BigInt   @id @default(autoincrement())
  assetId   String
  timeframe Int
  openTime  DateTime
  open      Decimal  @db.Decimal(18, 5)
  high      Decimal  @db.Decimal(18, 5)
  low       Decimal  @db.Decimal(18, 5)
  close     Decimal  @db.Decimal(18, 5)

  asset OtcAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, timeframe, openTime])
  @@index([assetId, timeframe, openTime(sort: Desc)])
  @@map("otc_candles")
}

model Transaction {
  id          String          @id @default(cuid())
  accountId   String
  type        TransactionType
  amount      Decimal         @db.Decimal(18, 2)
  description String?
  createdAt   DateTime        @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("transactions")
}
